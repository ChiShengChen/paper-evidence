# Copy to `.env` (gitignored). The verification core needs no key; card extraction and
# the cross-family faithfulness judge need at least one LLM provider (two families is
# better — the judge then differs from the extractor).

PAPER_EVIDENCE_PROVIDER=gemini        # gemini | deepseek | anthropic (default: gemini)
# PAPER_EVIDENCE_MODEL=gemini-2.5-flash   # optional model override for that provider

# --- LLM providers (fill in whichever you use) ---
GEMINI_API_KEY=AIza...
# GOOGLE_API_KEY=AIza...              # also accepted for Gemini
DEEPSEEK_API_KEY=sk-...               # a 2nd family enables the cross-family judge
# ANTHROPIC_API_KEY=sk-ant-...

# --- paper-deep-search bridge (optional, free; for the search/fetch layer) ---
# SEMANTIC_SCHOLAR_API_KEY=...        # strongly recommended: avoids 429s in search/snowball
# CONTACT_EMAIL=you@example.com       # polite mailto for OpenAlex / Crossref / Unpaywall
# CORE_API_KEY=...                    # enables the CORE source
# NCBI_API_KEY=...                    # higher PubMed rate limits
# UNPAYWALL_EMAIL=you@example.com     # Unpaywall OA-PDF fallback
